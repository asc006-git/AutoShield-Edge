# AutoShield Edge - .gitignore

# ============================================
# Large Data Files
# ============================================
dataset/
*.csv
*.txt
!README.md
*.parquet
!data/behavioral/*.parquet
*.pkl
*.joblib
!data/models/*.joblib
*.h5
*.hdf5
*.npy
*.npz

# ============================================
# Logs
# ============================================
*.log
logs/

# ============================================
# Python Bytecode & Cache
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# ============================================
# Virtual Environment
# ============================================
.venv/
venv/
env/
.conda/
ENV/

# ============================================
# IDE & Editor
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.iml

# ============================================
# Jupyter Notebook artifacts
# ============================================
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ============================================
# Environment & Secrets
# ============================================
.env
.env.local
.env.*.local
*.key
*.pem
*.cert

# ============================================
# OS & System
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# Node / Next.js Build Artifacts
# ============================================
node_modules/
dashboard/.next/
dashboard/out/
dashboard/tsconfig.tsbuildinfo
dashboard/next-env.d.ts

# ============================================
# Generated Assets (tracked via exceptions below)
# ============================================
# assets/ and reports/*.md are NOT excluded —
# they are part of the submission package
